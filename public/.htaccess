Options -MultiViews
RewriteEngine On

# Content-hashed assets live under /assets/. If one is missing it means a stale
# client is requesting an old chunk hash — return a clean 404 instead of falling
# through to the SPA shell below (which would serve index.html as text/html and
# break dynamic import() with a confusing MIME-type error).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^assets/.+ - [R=404,L]

# SPA fallback: everything else that isn't a real file/dir serves the app shell.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [QSA,L]

# Cache policy. Vite emits content-hashed asset filenames (e.g.
# Profile-D6Y6Dvmo.js), so those are safe to cache forever. index.html is the
# unhashed entry point and must always be revalidated, otherwise a cached client
# keeps requesting old chunk hashes that no longer exist after a deploy.
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|svg|png|jpe?g|webp|gif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
