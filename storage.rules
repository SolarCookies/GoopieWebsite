rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Game images — admins and assigned developers can upload
    match /games/{gameId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && (
          firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
          || (
            firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'developer'
            && gameId in firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.assignedGames
          )
        )
        && request.resource.size < 10 * 1024 * 1024 // 10MB max
        && request.resource.contentType.matches('image/.*');
    }
  }
}
